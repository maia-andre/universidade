# Modelo das credenciais de assinatura de release (V8 Item 3).
#
# COMO USAR:
#   1. Copie este arquivo para `keystore.properties` (na raiz do projeto).
#   2. Preencha os 4 valores abaixo com os dados da sua upload key.
#   3. NÃO versione o keystore.properties — ele já está no .gitignore.
#
# Depois disso, `./gradlew bundleRelease` gera o .aab JÁ ASSINADO em
#   app/build/outputs/bundle/release/app-release.aab
#
# Caminho absoluto da .jks (a pasta separada onde você guardou a upload key):
storeFile=/caminho/absoluto/para/upload-key.jks
# Senha do keystore:
storePassword=COLOQUE_A_SENHA_DO_KEYSTORE
# Alias da chave dentro do keystore:
keyAlias=COLOQUE_O_ALIAS
# Senha da chave (frequentemente igual à do keystore):
keyPassword=COLOQUE_A_SENHA_DA_CHAVE
